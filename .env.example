# =============================================================================
#  MinnesotaLakeHomesForSale.com — environment template
#  Copy to .env.local (dev) or set in Render (prod). NEVER commit real values.
#  Legend:  [REQUIRED] launch-blocker  ·  [RECOMMENDED]  ·  [OPTIONAL] feature flag
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production                       # [REQUIRED] "development" locally
PORT=3000                                 # [OPTIONAL] Render sets this automatically
DATABASE_URL=postgres://user:pass@host:5432/dbname   # [REQUIRED] Postgres connection
JWT_SECRET=change-me-to-a-long-random-string         # [REQUIRED] signs auth tokens
SITE_URL=https://minnesotalakehomesforsale.com       # [REQUIRED] canonical public URL
BASE_URL=https://minnesotalakehomesforsale.com       # [REQUIRED] Stripe success/cancel redirects — defaults to localhost:3000 if unset (breaks checkout in prod)

# ── Stripe (agent subscriptions) ─────────────────────────────────────────────
# Without these, pricing shows "coming soon" and checkout returns 500.
STRIPE_SECRET_KEY=sk_live_xxx             # [REQUIRED] live secret key
STRIPE_WEBHOOK_SECRET=whsec_xxx           # [REQUIRED] MUST match the LIVE endpoint's signing
                                          #   secret (Stripe → Webhooks → https://<domain>/api/stripe/webhook)
                                          #   Wrong/missing = agents pay but are never activated.
# Agent tier price IDs (create Products in Stripe, paste the price_ IDs):
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx   # [REQUIRED] Standard $9/mo
STRIPE_PRICE_STANDARD_ANNUAL=price_xxx    # [REQUIRED]
STRIPE_PRICE_PRIME_MONTHLY=price_xxx      # [REQUIRED] Prime $39/mo
STRIPE_PRICE_PRIME_ANNUAL=price_xxx       # [REQUIRED]
STRIPE_PRICE_FOUNDER_MONTHLY=price_xxx    # [REQUIRED] Founder / Elite $149/mo
STRIPE_PRICE_FOUNDER_ANNUAL=price_xxx     # [REQUIRED]
# Business/partner price IDs (only if selling business listings):
STRIPE_PRICE_BUSINESS_MONTHLY=price_xxx           # [OPTIONAL]
STRIPE_PRICE_BUSINESS_BASIC_MONTHLY=price_xxx     # [OPTIONAL]
STRIPE_PRICE_BUSINESS_BASIC_ANNUAL=price_xxx      # [OPTIONAL]
STRIPE_PRICE_BUSINESS_PREMIUM_MONTHLY=price_xxx   # [OPTIONAL]
STRIPE_PRICE_BUSINESS_PREMIUM_ANNUAL=price_xxx    # [OPTIONAL]
# Optional display-price overrides (STRIPE_PRICING_* — human-readable amounts shown
# on the pricing page; falls back to hardcoded defaults if unset):
# STRIPE_PRICING_STANDARD_MONTHLY=9

# ── Email (Resend OR Gmail — pick one transport) ─────────────────────────────
RESEND_API_KEY=re_xxx                     # [REQUIRED*] Resend transport (preferred)
# GMAIL_USER=you@gmail.com                # [REQUIRED*] Gmail SMTP fallback (use if no Resend)
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx  #            Gmail app password (not your login pw)
#   *At least one transport is required or ALL email silently fails to send.
#   Deliverability: verify your domain with SPF + DKIM + DMARC in Resend or spam-foldering awaits.
EMAIL_FROM=MN Lake Homes <hello@minnesotalakehomesforsale.com>   # [RECOMMENDED]
EMAIL_REPLY_TO=minnesotalakehomesforsale@gmail.com               # [RECOMMENDED]
EMAIL_PHYSICAL_ADDRESS=123 Main St, City, MN 55000               # [REQUIRED] CAN-SPAM: real postal
                                          #   address on every marketing email (PO box ok)
LEAD_NOTIFY_EMAIL=leads@minnesotalakehomesforsale.com  # [RECOMMENDED] where new leads are emailed
ADMIN_EMAIL=you@example.com               # [RECOMMENDED] admin/ops notifications

# ── Images (Cloudinary) ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxx                 # [REQUIRED] image hosting/uploads
CLOUDINARY_API_KEY=xxx                    # [REQUIRED]
CLOUDINARY_API_SECRET=xxx                 # [REQUIRED]

# ── Analytics & monitoring ───────────────────────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXX              # [RECOMMENDED] Google Analytics 4 (dark if unset)
GSC_VERIFICATION=xxx                      # [OPTIONAL] Google Search Console meta tag
SENTRY_DSN=https://xxx@sentry.io/xxx      # [OPTIONAL] error monitoring

# ── SMS lead alerts (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx                  # [OPTIONAL] SMS alerts off if unset (degrades gracefully)
TWILIO_AUTH_TOKEN=xxx                     # [OPTIONAL]
TWILIO_FROM=+1xxxxxxxxxx                   # [OPTIONAL] OR use a messaging service below
TWILIO_MESSAGING_SERVICE_SID=MGxxx        # [OPTIONAL]

# ── Data enrichment / IDX (all optional feature flags) ───────────────────────
GOOGLE_PLACES_API_KEY=xxx                 # [OPTIONAL] business/place enrichment
GOOGLE_SERVER_KEY=xxx                     # [OPTIONAL] server-side Google API key
RENTCAST_API_KEY=xxx                      # [OPTIONAL] home valuation estimates
OPENAI_API_KEY=sk-xxx                     # [OPTIONAL] AI marketing copy + blog covers
OPENAI_MODEL=gpt-4o-mini                  # [OPTIONAL] default model
MLS_FEED_URL=                             # [OPTIONAL] IDX/MLS feed endpoint (feature idle if unset)
MLS_FEED_TOKEN=                           # [OPTIONAL]
MLS_FEED_MAX_PAGES=                       # [OPTIONAL]
MLS_FEED_RETIRE=                          # [OPTIONAL]
DNR_ENRICH_ENABLED=false                  # [OPTIONAL] MN DNR lake-data enrichment
TURNSTILE_SECRET=xxx                      # [OPTIONAL] Cloudflare Turnstile spam protection

# ── CRM sync (HubSpot) ───────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-xxx              # [OPTIONAL] push leads to HubSpot
HUBSPOT_PORTAL_ID=xxx                     # [OPTIONAL]
HUBSPOT_REGION=na1                        # [OPTIONAL]
HUBSPOT_ENABLE_SYNC=false                 # [OPTIONAL] master toggle

# ── Feature flags & tunables ─────────────────────────────────────────────────
LISTINGS_PUBLIC=false                     # [OPTIONAL] expose property listings publicly
FOUNDER_SEATS_PUBLIC=false                # [OPTIONAL] show founder-seat availability publicly
SEED_DEMO_FREE_AGENT=false                # [OPTIONAL] seed the demo free-tier agent on boot
NURTURE_ENABLED=false                     # [OPTIONAL] automated lead nurture emails
BUYER_DIGEST_ENABLED=false                # [OPTIONAL] periodic buyer digest
WIN_BACK_ENABLED=false                    # [OPTIONAL] churned-agent win-back emails
CHURN_SWEEP_ENABLED=false                 # [OPTIONAL] churn sweep job
LEAD_SLA_ENABLED=false                    # [OPTIONAL] lead SLA/response-time tracking
AGENT_ROI_EMAIL_ENABLED=false            # [OPTIONAL] agent ROI report emails
# ROI calculator defaults (dollars / percentages):
AGENT_ROI_AVG_SALE_USD=450000             # [OPTIONAL]
AGENT_ROI_CLOSE_RATE=0.03                 # [OPTIONAL]
AGENT_ROI_COMMISSION_PCT=0.03             # [OPTIONAL]
CASH_OFFER_VALUE_USD=                     # [OPTIONAL]
BOOST_PRICE_PER_DAY_USD=                  # [OPTIONAL]
PARTNER_REFERRAL_FEE_USD=                 # [OPTIONAL]

# ── Set automatically by Render (do not set manually) ────────────────────────
# RENDER_DEPLOY_TIME / RENDER_GIT_COMMIT
